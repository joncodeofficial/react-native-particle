{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "particle"
  ],
  "ios": {
    "iosModuleName": "Particle"
  },
  "android": {
    "androidNamespace": [
      "particle"
    ],
    "androidCxxLibName": "Particle"
  },
  "autolinking": {
    "Particle": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridParticle"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}