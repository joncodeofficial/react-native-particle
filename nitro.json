{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "particle"
  ],
  "ios": {
    "iosModuleName": "Particle"
  },
  "android": {
    "androidNamespace": [
      "particle"
    ],
    "androidCxxLibName": "Particle"
  },
  "autolinking": {
    "ParticleEngine": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridParticleEngine"
      }
    },
    "ParticleCanvasView": {
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridParticleCanvasView"
      },
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridParticleCanvasView"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
